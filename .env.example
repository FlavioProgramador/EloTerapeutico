# Ambiente local do Docker Compose. Copie para .env e não versione o arquivo real.

# Django
SECRET_KEY=configure-segredo-local-django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
FRONTEND_URL=http://localhost:3000
TRUST_PROXY_CLIENT_IP_HEADERS=False

# PostgreSQL do compose
POSTGRES_DB=elo_terapeutico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=configure-senha-local-postgres
DATABASE_URL=postgres://postgres:configure-senha-local-postgres@db:5432/elo_terapeutico

# JWT e campos criptografados — use valores distintos
JWT_SECRET=configure-segredo-local-jwt
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
FIELD_ENCRYPTION_KEY=configure-chave-local-de-dados

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/

# Storage local em desenvolvimento
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=elo-terapeutico
AZURE_URL_EXPIRATION_SECS=300
PRIVATE_MEDIA_STORAGE_REQUIRED=False

# Asaas e operação de billing
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=configure-token-local-webhook
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL
BILLING_GRACE_PERIOD_DAYS=5
BILLING_MAX_INSTALLMENTS=12
BILLING_WEBHOOK_MAX_RETRIES=5
# True apenas no ambiente local; em produção deixe False e execute o worker.
BILLING_WEBHOOK_PROCESS_INLINE=True
BILLING_RECONCILIATION_ENABLED=True
BILLING_RECONCILIATION_INTERVAL_MINUTES=60
BILLING_CHECKOUT_EXPIRATION_MINUTES=30

# E-mail — desenvolvimento usa console
DEFAULT_FROM_EMAIL=noreply@example.test
EMAIL_HOST=smtp.example.test
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
