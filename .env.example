# .env.example

# ==== Backend (Django) ====
# Django secret key (keep secret!)
SECRET_KEY=your-secret-key-here

# Database connection (PostgreSQL) – format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@db:5432/elo_terapeutico

# JWT secret for SimpleJWT
JWT_SECRET=your-jwt-secret

# Azure Blob Storage connection string (for storing documents)
AZURE_STORAGE_CONNECTION_STRING=your-azure-blob-connection-string

# Debug mode (True for local dev, False for prod)
DEBUG=True

# Allowed hosts (comma‑separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ==== Frontend (Next.js) ====
# Public API URL that the frontend will call (backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/
FRONTEND_URL=http://localhost:3000

# Azure Blob endpoint (optional, used by frontend for direct uploads)
NEXT_PUBLIC_AZURE_BLOB_URL=https://youraccount.blob.core.windows.net/yourcontainer

# ==== Asaas Sandbox / Billing ====
# Never commit real Asaas keys. Use the sandbox URL in development.
# When testing webhooks with ngrok, add the ngrok host to ALLOWED_HOSTS without https://.
# In the root Docker Compose .env, escape a leading Asaas $ as $$.
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL
