# Ambiente canônico do Docker Compose. Copie para .env na raiz e não versione o arquivo real.
# Alterações neste arquivo exigem recriar backend e workers para atualizar o ambiente.

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=configure-segredo-local-django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000
TRUST_PROXY_CLIENT_IP_HEADERS=False
HEALTH_CHECK_STORAGE=False

# SQL Explorer administrativo — desligado por padrão e proibido em produção.
ADMIN_SQL_EXPLORER_ENABLED=False
ADMIN_SQL_EXPLORER_DATABASE_ALIAS=default
ADMIN_SQL_EXPLORER_MAX_ROWS=100
ADMIN_SQL_EXPLORER_TIMEOUT_MS=2000
ADMIN_SQL_EXPLORER_ALLOWED_TABLES=django_migrations

# PostgreSQL do compose
POSTGRES_DB=config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=configure-senha-local-postgres
DATABASE_URL=postgres://postgres:configure-senha-local-postgres@db:5432/config

# Redis e Celery — use senha forte e rede privada em produção
REDIS_PASSWORD=configure-senha-local-redis
REDIS_URL=redis://:configure-senha-local-redis@redis:6379/0
REDIS_RESULT_URL=redis://:configure-senha-local-redis@redis:6379/1
CELERY_BROKER_URL=redis://:configure-senha-local-redis@redis:6379/0
CELERY_RESULT_BACKEND=redis://:configure-senha-local-redis@redis:6379/1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_VISIBILITY_TIMEOUT_SECONDS=3600
CELERY_RESULT_EXPIRES_SECONDS=3600
CELERY_TASK_SOFT_TIME_LIMIT_SECONDS=300
CELERY_TASK_TIME_LIMIT_SECONDS=360
CELERY_EXPORT_CONCURRENCY=1
CELERY_COMMUNICATIONS_CONCURRENCY=2
CELERY_DEFAULT_CONCURRENCY=1

# Exportações clínicas
CLINICAL_EXPORT_DISPATCH_BATCH_SIZE=20
CLINICAL_EXPORT_PROCESSING_TIMEOUT_MINUTES=15
CLINICAL_EXPORT_MAX_RETRIES=3
CLINICAL_EXPORT_RETENTION_HOURS=24
EXPORT_DISPATCH_INTERVAL_SECONDS=10
EXPORT_RECOVERY_INTERVAL_SECONDS=300

# JWT e campos criptografados — use valores distintos
JWT_SECRET=configure-segredo-local-jwt
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
FIELD_ENCRYPTION_KEY=configure-chave-local-de-dados

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/

# Telemedicina — desligada por padrão. Não use credenciais reais neste arquivo.
TELEMEDICINE_ENABLED=False
TELEMEDICINE_PROVIDER=livekit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
TELEMEDICINE_REQUIRE_E2EE=True
TELEMEDICINE_JOIN_BEFORE_MINUTES=15
TELEMEDICINE_JOIN_AFTER_MINUTES=30
TELEMEDICINE_PROVIDER_TOKEN_TTL_SECONDS=300
TELEMEDICINE_EMPTY_ROOM_TIMEOUT_SECONDS=300
TELEMEDICINE_MAX_PARTICIPANTS=2
TELEMEDICINE_MAINTENANCE_INTERVAL_SECONDS=300

# Storage local em desenvolvimento; Azure privado é obrigatório em produção por padrão
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=elo-terapeutico
AZURE_URL_EXPIRATION_SECS=300
PRIVATE_MEDIA_STORAGE_REQUIRED=False

# Asaas e operação de billing
BILLING_ENABLED=True
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=configure-token-local-webhook
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL
BILLING_GRACE_PERIOD_DAYS=5
BILLING_MAX_INSTALLMENTS=12
BILLING_WEBHOOK_MAX_RETRIES=5
BILLING_WEBHOOK_DISPATCH_BATCH_SIZE=50
BILLING_WEBHOOK_RESERVATION_TIMEOUT_MINUTES=5
BILLING_WEBHOOK_DISPATCH_INTERVAL_SECONDS=15
# True somente em testes locais específicos. Em produção use False.
BILLING_WEBHOOK_PROCESS_INLINE=False
BILLING_RECONCILIATION_ENABLED=True
BILLING_RECONCILIATION_INTERVAL_MINUTES=60
BILLING_RECONCILIATION_BATCH_SIZE=50
BILLING_CHECKOUT_EXPIRATION_MINUTES=30

# E-mail — desenvolvimento usa console; produção deve configurar SMTP real.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.test
EMAIL_HOST=smtp.example.test
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=15

# Comunicações
COMMUNICATIONS_ENABLED=True
COMMUNICATIONS_BATCH_SIZE=50
COMMUNICATIONS_MAX_ATTEMPTS=5
COMMUNICATIONS_PROCESSING_TIMEOUT_MINUTES=15
COMMUNICATIONS_DEFAULT_TIMEZONE=America/Sao_Paulo
COMMUNICATIONS_REPLY_TO=
COMMUNICATIONS_DISPATCH_INTERVAL_SECONDS=20
COMMUNICATIONS_AUTOMATION_INTERVAL_SECONDS=300
COMMUNICATIONS_PAYMENT_DUE_DAYS=3
COMMUNICATIONS_FORM_REMINDER_HOURS=24
COMMUNICATIONS_DOCUMENT_REMINDER_HOURS=24
COMMUNICATIONS_TOKEN_RETENTION_DAYS=90

# WhatsApp Business — permanece desativado enquanto não houver configuração completa.
WHATSAPP_PROVIDER=
WHATSAPP_API_BASE_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# SMS — interface preparada; escolha e configure um provedor antes de ativar.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=
