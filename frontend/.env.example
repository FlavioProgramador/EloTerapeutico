# URL usada exclusivamente pelo servidor Next.js. Não é incorporada ao bundle.
# Docker Compose: use o nome interno do serviço Django.
BACKEND_API_URL=http://backend:8000/api/v1/

# Fallback público para desenvolvimento fora do Docker.
# Nunca coloque segredos em variáveis NEXT_PUBLIC_*.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/

# Expiração dos cookies de sessão em segundos.
AUTH_ACCESS_COOKIE_MAX_AGE=1800
AUTH_REFRESH_COOKIE_MAX_AGE=604800
