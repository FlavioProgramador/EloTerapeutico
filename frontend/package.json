{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test *.test.mjs",
    "test:coverage": "node --experimental-strip-types --experimental-test-coverage --test --test-coverage-lines=80 --test-coverage-functions=75 --test-coverage-branches=70 *.test.mjs",
    "test:agenda": "node --experimental-strip-types --test agenda-calendar.test.mjs",
    "test:auth": "node --experimental-strip-types --test auth-flow.test.mjs auth-bff-policy.test.mjs",
    "test:e2e": "npm --prefix e2e run test",
    "test:e2e:auth": "npm --prefix e2e run test:auth",
    "test:e2e:gateway": "npm --prefix e2e run test:gateway"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@livekit/components-react": "^2.9.23",
    "@livekit/components-styles": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.41.0",
    "livekit-client": "^2.20.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.11",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.11",
    "tailwindcss": "^4",
    "typescript": "^6"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.0"
  }
}
