# Uso exclusivo ao executar o backend diretamente, fora do Docker.
# Copie para backend/.env. No Docker Compose, use somente o .env da raiz.
# django-environ não sobrescreve variáveis que já foram injetadas no processo.

# Django
SECRET_KEY=configure-segredo-local-django
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY_CLIENT_IP_HEADERS=False

# Banco: SQLite local ou PostgreSQL
DATABASE_URL=sqlite:///local.sqlite3
POSTGRES_DB=elo_terapeutico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=configure-senha-local-postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET=configure-segredo-local-jwt
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Criptografia de campos sensíveis
FIELD_ENCRYPTION_KEY=configure-chave-local-de-dados
# FIELD_ENCRYPTION_KEY_V2=configure-chave-nova-durante-rotacao

# Documentos
DOCUMENT_CLINIC_NAME=Elo Terapêutico
DOCUMENT_CLINIC_ADDRESS=
DOCUMENT_CLINIC_PHONE=

# Azure Blob opcional em desenvolvimento
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=elo-terapeutico
AZURE_URL_EXPIRATION_SECS=300
PRIVATE_MEDIA_STORAGE_REQUIRED=False

# Asaas e operação de billing
BILLING_ENABLED=True
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=configure-token-local-webhook
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL
BILLING_GRACE_PERIOD_DAYS=5
BILLING_MAX_INSTALLMENTS=12
BILLING_WEBHOOK_MAX_RETRIES=5
# True apenas em desenvolvimento/testes; produção deve usar o worker persistido.
BILLING_WEBHOOK_PROCESS_INLINE=True
BILLING_RECONCILIATION_ENABLED=True
BILLING_RECONCILIATION_INTERVAL_MINUTES=60
BILLING_CHECKOUT_EXPIRATION_MINUTES=30

# E-mail: settings dev usa console; produção deve configurar SMTP.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@example.test
EMAIL_HOST=smtp.example.test
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=15

# Comunicações
COMMUNICATIONS_ENABLED=True
COMMUNICATIONS_BATCH_SIZE=50
COMMUNICATIONS_MAX_ATTEMPTS=5
COMMUNICATIONS_PROCESSING_TIMEOUT_MINUTES=15
COMMUNICATIONS_DEFAULT_TIMEZONE=America/Sao_Paulo
COMMUNICATIONS_REPLY_TO=

# WhatsApp Business — opcional e desativado sem configuração completa.
WHATSAPP_PROVIDER=
WHATSAPP_API_BASE_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# SMS — opcional; a interface permanece desativada sem provedor.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=

# Referência do frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1/
