# ==============================================================================
# .env para desenvolvimento local
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o .env real no repositório!
# ==============================================================================

# Django
SECRET_KEY=changeme
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Em produção no Azure, permita cabeçalhos de IP somente quando a aplicação
# estiver efetivamente atrás do proxy gerenciado.
TRUST_PROXY_CLIENT_IP_HEADERS=False

# Banco de dados PostgreSQL
DATABASE_URL=sqlite:///local.sqlite3
POSTGRES_DB=elo_terapeutico
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET=changeme
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Criptografia de campos sensíveis (prontuários e documentos)
# Gere uma chave segura localmente: python -c "import secrets; print(secrets.token_hex(32))"
FIELD_ENCRYPTION_KEY=changeme

# Identificação opcional nos documentos gerados
DOCUMENT_CLINIC_NAME=Elo Terapêutico
DOCUMENT_CLINIC_ADDRESS=
DOCUMENT_CLINIC_PHONE=

# Azure Blob Storage (opcional em dev – deixe vazio para usar storage local)
# Em produção, configure PRIVATE_MEDIA_STORAGE_REQUIRED=True para impedir que a
# aplicação inicie sem armazenamento privado e persistente.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=elo-terapeutico
AZURE_URL_EXPIRATION_SECS=300
PRIVATE_MEDIA_STORAGE_REQUIRED=False

# Asaas Sandbox / Billing
# Em backend/.env, cole a chave do Asaas exatamente como copiada do sandbox.
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL

# E-mail (em dev usa console backend, ignorar abaixo)
DEFAULT_FROM_EMAIL=noreply@eloterapeutico.com.br
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend (Next.js) – apenas referência
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
