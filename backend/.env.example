# ==============================================================================
# .env para desenvolvimento local
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o .env real no repositório!
# ==============================================================================

# Django
SECRET_KEY=django-insecure-dev-key-mude-em-producao-1234567890abcdef
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de dados PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/elo_terapeutico
POSTGRES_DB=elo_terapeutico
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT
JWT_SECRET=dev-jwt-secret-mude-em-producao-xyz
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Criptografia de campos sensíveis (prontuários e documentos)
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
FIELD_ENCRYPTION_KEY=dev-encryption-key-mude-em-producao-abcdef1234567890

# Identificação opcional nos documentos gerados
DOCUMENT_CLINIC_NAME=Elo Terapêutico
DOCUMENT_CLINIC_ADDRESS=
DOCUMENT_CLINIC_PHONE=

# Azure Blob Storage (opcional em dev – deixe vazio para usar storage local)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=elo-terapeutico

# Asaas Sandbox / Billing
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=dev-webhook-token
BILLING_TRIAL_DAYS=7
BILLING_DEFAULT_CURRENCY=BRL

# E-mail (em dev usa console backend, ignorar abaixo)
DEFAULT_FROM_EMAIL=noreply@eloterapeutico.com.br
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Frontend (Next.js) – apenas referência
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
